# Normalize line endings for cross-platform consistency
* text=auto

# Explicitly use LF for these file types
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary files - no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
